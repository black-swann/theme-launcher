    def _install_css(self):
        provider = Gtk.CssProvider()
        provider.load_from_data(APP_CSS_PATH.read_bytes())
        display = Gdk.Display.get_default()
        if display is not None:
            Gtk.StyleContext.add_provider_for_display(
                display,
                provider,
                Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION,
            )

    def load_themes(self):
        started = time.monotonic()
        bootstrap = json.loads(run_cli("bootstrap").stdout)
        self.theme_metadata = {item["slug"]: item for item in bootstrap["metadata"]}
        themes = list(self.theme_metadata)
        self.current_theme = bootstrap.get("current", "")
        self.initial_theme = self.current_theme
        self.current_wallpaper = (
            self.metadata_for(self.current_theme).get("current_wallpaper")
            or self.metadata_for(self.current_theme).get("selected_wallpaper", "")
        )
        self.initial_wallpaper = self.current_wallpaper
        self.default_theme = bootstrap.get("default", "")

        for theme in themes:
            row = ThemeRow(theme, self)
            row.refresh()
            self.rows.append(row)
            self.list_box.append(row)

        self.apply_filters(refresh_status=False)

        selected_theme = (
            self.gui_state.get("selected_theme")
            if isinstance(self.gui_state, dict)
            else ""
        )
        if selected_theme not in themes:
            selected_theme = self.current_theme or self.default_theme
        if selected_theme:
            self._suspend_selection_apply = True
            self.select_theme(selected_theme)
            self._suspend_selection_apply = False

        if selected_theme:
            elapsed_ms = int((time.monotonic() - started) * 1000)
            self.set_status(f"Current theme: {display_name(selected_theme)} · loaded in {elapsed_ms} ms", busy=False)
        else:
            self.set_status("Select a theme to inspect it.", busy=False)
        self.refresh_preview()

    def reload_metadata(self):
        self.theme_metadata = {
            item["slug"]: item
            for item in json.loads(run_cli("metadata").stdout)
        }

    def select_theme(self, theme):
        for row in self.rows:
            if row.theme == theme:
                if not row.get_visible():
                    continue
                self.list_box.select_row(row)
                break

    def selected_theme(self):
        row = self.list_box.get_selected_row()
        return row.theme if row is not None else None

    def metadata_for(self, theme):
        return self.theme_metadata.get(theme, {
            "slug": theme,
            "name": display_name(theme),
            "variant": "dark",
            "description": "",
            "badges": [],
            "preview_path": "",
            "wallpapers": [],
            "selected_wallpaper": "",
            "current_wallpaper": "",
        })

    def _mark_recent_theme(self, theme):
        if not theme:
            return
        self.recent_themes = [item for item in self.recent_themes if item != theme]
        self.recent_themes.insert(0, theme)
        self.recent_themes = self.recent_themes[:MAX_RECENT_THEMES]
        write_recent_themes(self.recent_themes)

    def _save_gui_state(self):
        if self._destroyed:
            return
        width = self.get_width()
        height = self.get_height()
        state = {
            "window_size": [width, height],
            "variant_filter": self.variant_filter,
            "preview_mode": self.preview_mode,
            "selected_theme": self.current_preview_theme() or "",
            "favorites_only": self.favorites_only,
            "recent_only": self.recent_only,
        }
        write_json_file(GUI_STATE_FILE, state)

    def _apply_summary_for(self, theme, metadata):
        source = "custom" if str(metadata.get("path", "")).startswith(str(Path.home())) else metadata.get("source", "theme")
        wallpaper_count = len(metadata.get("wallpapers", []))
        parts = [
            "Apply updates GNOME, GTK, Ghostty, terminal tools, editor colors, and wallpaper when available.",
            "GNOME Shell and Chromium stay opt-in unless explicitly enabled.",
        ]
        if wallpaper_count:
            parts.append(f"{wallpaper_count} wallpaper option(s) available.")
        if source:
            parts.append(f"Source: {source}.")
        return " ".join(parts)

    def _preview_sources_for(self, theme, metadata):
        return {
            "workspace": metadata.get("preview_path", ""),
            "wallpaper": self._selected_wallpaper_path_for(theme, metadata),
        }

    def _sync_preview_mode(self, theme, metadata):
        sources = self._preview_sources_for(theme, metadata)
        if sources.get(self.preview_mode):
            chosen_mode = self.preview_mode
        elif sources.get("workspace"):
            chosen_mode = "workspace"
        elif sources.get("wallpaper"):
            chosen_mode = "wallpaper"
        else:
            chosen_mode = "workspace"

        self.preview_mode = chosen_mode

        for mode_key, button in self.preview_mode_buttons.items():
            has_source = bool(sources.get(mode_key))
            button.set_sensitive(has_source)
            if button.get_active() != (mode_key == chosen_mode):
                button.set_active(mode_key == chosen_mode)

        return sources.get(chosen_mode, "")

    def _clear_preview_mode(self):
        self.preview_mode = "workspace"
        for mode_key, button in self.preview_mode_buttons.items():
            button.set_sensitive(False)
            if button.get_active() != (mode_key == self.preview_mode):
                button.set_active(mode_key == self.preview_mode)

    def refresh_preview(self, update_wallpaper_selector=True):
        theme = self.selected_theme() or self.current_theme or self.default_theme
        if not theme:
            self.preview_name_label.set_text("No theme selected")
            self.preview_meta_label.set_text("Choose a theme to inspect its preview.")
            self.preview_description_label.set_text("")
            self.apply_summary_label.set_text("")
            self._clear_preview_badges()
            self.preview_picture.set_paintable(None)
            self.preview_favorite_button.set_label("Add Favorite")
            self.preview_default_button.set_sensitive(False)
            self._clear_preview_mode()
            self._update_wallpaper_selector(None, None)
            return

        metadata = self.metadata_for(theme)
        self.preview_name_label.set_text(metadata.get("name") or display_name(theme))

        meta_parts = [theme_row_summary(theme, metadata)]
        if theme == self.current_theme:
            meta_parts.append("Current")
        if theme == self.default_theme:
            meta_parts.append("Default")
        if theme == self.pending_theme:
            meta_parts.append("Applying")
        self.preview_meta_label.set_text("  ".join(meta_parts))

        description = metadata.get("description") or "Catalog preview image for this theme."
        self.preview_description_label.set_text(description)
        self.apply_summary_label.set_text(self._apply_summary_for(theme, metadata))

        self._set_preview_badges(metadata)
        preview_path = self._sync_preview_mode(theme, metadata)
        self._set_preview_image(preview_path)
        if update_wallpaper_selector:
            self._update_wallpaper_selector(theme, metadata)
        self.preview_favorite_button.set_label(
            "Remove Favorite" if metadata.get("favorite") else "Add Favorite"
        )
        self.preview_default_button.set_sensitive(theme != self.default_theme)

    def _set_preview_image(self, preview_path):
        if not preview_path:
            self.preview_picture.set_paintable(None)
            return

        try:
            stat = Path(preview_path).stat()
            cache_key = (preview_path, stat.st_mtime_ns)
            texture = self._preview_texture_cache.get(cache_key)
            if texture is None:
                scaled = GdkPixbuf.Pixbuf.new_from_file_at_scale(
                    preview_path,
                    PREVIEW_IMAGE_WIDTH,
                    PREVIEW_IMAGE_HEIGHT,
                    True,
                )
                pixbuf = GdkPixbuf.Pixbuf.new(
                    GdkPixbuf.Colorspace.RGB,
                    True,
                    8,
                    PREVIEW_IMAGE_WIDTH,
                    PREVIEW_IMAGE_HEIGHT,
                )
                pixbuf.fill(0x00000000)
                x_offset = max((PREVIEW_IMAGE_WIDTH - scaled.get_width()) // 2, 0)
                y_offset = max((PREVIEW_IMAGE_HEIGHT - scaled.get_height()) // 2, 0)
                scaled.copy_area(
                    0,
                    0,
                    scaled.get_width(),
                    scaled.get_height(),
                    pixbuf,
                    x_offset,
                    y_offset,
                )
                texture = Gdk.Texture.new_for_pixbuf(pixbuf)
                self._preview_texture_cache[cache_key] = texture
                if len(self._preview_texture_cache) > PREVIEW_CACHE_LIMIT:
                    oldest_key = next(iter(self._preview_texture_cache))
                    self._preview_texture_cache.pop(oldest_key, None)
        except (GLib.Error, OSError):
            self.preview_picture.set_paintable(None)
            return

        self.preview_picture.set_paintable(texture)

    def _set_preview_badges(self, metadata):
        self._clear_preview_badges()
        badges = list(metadata.get("badges", []))
        if metadata.get("favorite"):
            badges.append("Favorite")
        if metadata.get("slug") == self.current_theme:
            badges.append("Current")
        if metadata.get("slug") == self.default_theme:
            badges.append("Default")

        for badge_text in badges[:5]:
            badge = Gtk.Label(label=badge_text.title())
            badge.add_css_class("preview-badge")
            self.preview_badges.append(badge)

    def _clear_preview_badges(self):
        child = self.preview_badges.get_first_child()
        while child is not None:
            next_child = child.get_next_sibling()
            self.preview_badges.remove(child)
            child = next_child

    def _selected_wallpaper_for(self, theme, metadata=None):
        if not theme:
            return ""
        if metadata is None:
            metadata = self.metadata_for(theme)
        wallpaper = self._local_wallpaper_choices.get(theme, "")
        if not wallpaper and theme == self.current_theme and self.current_wallpaper:
            wallpaper = self.current_wallpaper
        if not wallpaper:
            wallpaper = metadata.get("selected_wallpaper") or ""
        if not wallpaper:
            wallpapers = metadata.get("wallpapers", [])
            if wallpapers:
                wallpaper = wallpapers[0].get("name", "")
        return wallpaper

    def _set_local_wallpaper_choice(self, theme, wallpaper):
        if theme and wallpaper:
            self._local_wallpaper_choices[theme] = wallpaper

    def _selected_wallpaper_path_for(self, theme, metadata=None):
        selected_wallpaper = self._selected_wallpaper_for(theme, metadata)
        if metadata is None:
            metadata = self.metadata_for(theme)
        for item in metadata.get("wallpapers", []):
            if item.get("name") == selected_wallpaper:
                return item.get("path", "")
        return ""

    def _update_wallpaper_selector(self, theme, metadata):
        self._suspend_wallpaper_change = True
        try:
            if not theme or metadata is None:
                self._wallpaper_choices = []
                self.wallpaper_dropdown.set_model(Gtk.StringList.new([]))
                self.wallpaper_dropdown.set_selected(Gtk.INVALID_LIST_POSITION)
                self.wallpaper_panel.set_visible(False)
                return

            wallpapers = metadata.get("wallpapers", [])
            self._wallpaper_choices = [item.get("name", "") for item in wallpapers if item.get("name")]
            labels = [
                item.get("label") or wallpaper_label(item.get("name", ""))
                for item in wallpapers
                if item.get("name")
            ]
            self.wallpaper_dropdown.set_model(Gtk.StringList.new(labels))

            selected_wallpaper = self._selected_wallpaper_for(theme, metadata)
            try:
                index = self._wallpaper_choices.index(selected_wallpaper)
            except ValueError:
                index = 0 if self._wallpaper_choices else Gtk.INVALID_LIST_POSITION
            self.wallpaper_dropdown.set_selected(index)
            self.wallpaper_panel.set_visible(len(self._wallpaper_choices) > 1)
        finally:
            self._suspend_wallpaper_change = False

    def _select_wallpaper_choice(self, wallpaper):
        try:
            index = self._wallpaper_choices.index(wallpaper)
        except ValueError:
            return

        self._suspend_wallpaper_change = True
        try:
            self.wallpaper_dropdown.set_selected(index)
        finally:
            self._suspend_wallpaper_change = False

    def refresh_rows(self):
        for row in self.rows:
            row.refresh()
        self.refresh_preview()

    def visible_themes(self):
        return [row.theme for row in self.rows if row.get_visible()]

    def apply_filters(self, refresh_status=True):
        selected_theme = self.selected_theme()

        for row in self.rows:
            metadata = self.metadata_for(row.theme)
            row_variant = metadata.get("variant", "dark")
            matches_variant = self.variant_filter == "all" or row_variant == self.variant_filter
            matches_favorite = not self.favorites_only or metadata.get("favorite")
            matches_recent = not self.recent_only or row.theme in self.recent_themes
            query = self.search_query.casefold()
            haystack = " ".join([
                row.theme,
                metadata.get("name", ""),
                metadata.get("description", ""),
                " ".join(metadata.get("badges", [])),
                " ".join(metadata.get("tags", [])),
            ]).casefold()
            matches_search = not query or query in haystack
            should_show = matches_variant and matches_favorite and matches_recent and matches_search
            row.set_visible(should_show)

        visible_themes = self.visible_themes()
        next_theme = None
        if selected_theme in visible_themes:
            next_theme = selected_theme
        elif self.current_theme in visible_themes:
            next_theme = self.current_theme
        elif self.default_theme in visible_themes:
            next_theme = self.default_theme
        elif visible_themes:
            next_theme = visible_themes[0]

        self._suspend_selection_apply = True
        if next_theme is None:
            self.list_box.unselect_all()
        else:
            self.select_theme(next_theme)
        self._suspend_selection_apply = False

        self.refresh_rows()

        if refresh_status:
            visible_count = len(visible_themes)
            filter_parts = []
            if self.variant_filter != "all":
                filter_parts.append(self.variant_filter)
            if self.favorites_only:
                filter_parts.append("favorites")
            if self.recent_only:
                filter_parts.append("recent")
            if self.search_query:
                filter_parts.append(f'matching "{self.search_query}"')

            if filter_parts:
                self.set_status(f"Showing {visible_count} theme(s): {', '.join(filter_parts)}", busy=False)
            else:
                self.set_status(f"Showing {visible_count} theme(s)", busy=False)

    def on_filter_toggled(self, button, filter_key):
        if not button.get_active():
            if self.variant_filter == filter_key:
                button.set_active(True)
            return

        for other_key, other_button in self.filter_buttons.items():
            if other_key != filter_key and other_button.get_active():
                other_button.set_active(False)

        if self.variant_filter == filter_key:
            return

        self.variant_filter = filter_key
        self._save_gui_state()
        self.apply_filters()

    def on_favorites_toggled(self, button):
        self.favorites_only = button.get_active()
        self._save_gui_state()
        self.apply_filters()

    def on_recent_toggled(self, button):
        self.recent_only = button.get_active()
        self._save_gui_state()
        self.apply_filters()

    def on_preview_mode_toggled(self, button, mode_key):
        if not button.get_active():
            if self.preview_mode == mode_key:
                button.set_active(True)
            return

        for other_key, other_button in self.preview_mode_buttons.items():
            if other_key != mode_key and other_button.get_active():
                other_button.set_active(False)

        if self.preview_mode == mode_key:
            return

        self.preview_mode = mode_key
        self._save_gui_state()
        self.refresh_preview()

    def on_desktop_preview_toggled(self, switch, _param):
        self.desktop_preview_enabled = switch.get_active()
        theme = self.selected_theme()

        if not self.desktop_preview_enabled:
            if self._preview_source_id:
                GLib.source_remove(self._preview_source_id)
                self._preview_source_id = 0
            self._queued_theme = None
            self._queued_wallpaper = None
            self._queued_close_on_success = False
            if theme:
                self.set_status(f"Inspecting {display_name(theme)} in launcher only", busy=False)
            return

        if theme is None:
            self.set_status("Desktop preview enabled", busy=False)
            return

        self.schedule_preview(theme, wallpaper=self._selected_wallpaper_for(theme), immediate=True)

    def on_search_changed(self, entry):
        if self._search_source_id:
            GLib.source_remove(self._search_source_id)
            self._search_source_id = 0

        self._search_source_id = GLib.timeout_add(
            SEARCH_FILTER_DELAY_MS,
            self._apply_search_query,
            entry.get_text().strip(),
        )

    def _apply_search_query(self, query):
        self._search_source_id = 0
        self.search_query = query
        self.apply_filters()
        return False

    def on_selection_changed(self, _list_box):
        if self._suspend_selection_apply:
            return

        theme = self.selected_theme()
        self.refresh_rows()
        if theme is None:
            return

        self._mark_recent_theme(theme)
        self._save_gui_state()

        if not self.desktop_preview_enabled:
            self.set_status(f"Inspecting {display_name(theme)} in launcher only", busy=False)
            return

        if theme != self.current_theme:
            self.schedule_preview(theme, wallpaper=self._selected_wallpaper_for(theme))

    def on_row_activated(self, _list_box, row):
        if self.desktop_preview_enabled:
            self.schedule_preview(row.theme, wallpaper=self._selected_wallpaper_for(row.theme), immediate=True)
        else:
            self.refresh_rows()
            self.set_status(f"Inspecting {display_name(row.theme)} in launcher only", busy=False)

    def on_wallpaper_selected(self, _dropdown, _param):
        if self._suspend_wallpaper_change or self.pending_theme is not None:
            return

        theme = self.selected_theme()
        if theme is None:
            return

        selected = self.wallpaper_dropdown.get_selected()
        if selected == Gtk.INVALID_LIST_POSITION or selected >= len(self._wallpaper_choices):
            return

        wallpaper = self._wallpaper_choices[selected]
        current_wallpaper = self._selected_wallpaper_for(theme)
        if wallpaper == current_wallpaper:
            return

        self._set_local_wallpaper_choice(theme, wallpaper)
        self.refresh_preview(update_wallpaper_selector=False)

        if self.desktop_preview_enabled:
            self.schedule_preview(theme, wallpaper=wallpaper, immediate=True)
        else:
            self.set_status(f"Selected wallpaper for {display_name(theme)}", busy=False)

    def on_wallpaper_randomize_clicked(self, _button):
        if self.pending_theme is not None:
            return

        theme = self.selected_theme()
        if theme is None:
            return

        if not self._wallpaper_choices:
            return

        wallpaper = random.choice(self._wallpaper_choices)
        self._set_local_wallpaper_choice(theme, wallpaper)
        self._select_wallpaper_choice(wallpaper)
        self.refresh_preview(update_wallpaper_selector=False)

        if self.desktop_preview_enabled:
            self.schedule_preview(theme, wallpaper=wallpaper, immediate=True)
        else:
            self.set_status(f"Selected random wallpaper for {display_name(theme)}", busy=False)

    def on_apply_clicked(self, _button):
        theme = self.selected_theme()
        if theme is None:
            return
        self._confirmed = True
        self._close_when_idle = False
        if self.pending_theme is not None and theme == self.pending_theme:
            self.close()
            return
        wallpaper = self._selected_wallpaper_for(theme)
        if theme == self.current_theme and wallpaper == self.current_wallpaper:
            self.close()
            return
        self.schedule_preview(theme, wallpaper=wallpaper, immediate=True, close_on_success=True)

    def schedule_preview(self, theme, wallpaper=None, immediate=False, close_on_success=False):
        if self._preview_source_id:
            GLib.source_remove(self._preview_source_id)
            self._preview_source_id = 0

        if self.pending_theme is not None:
            queued_theme_was = self._queued_theme
            self._queued_theme = theme
            self._queued_wallpaper = wallpaper
            self._queued_close_on_success = (
                close_on_success
                if queued_theme_was != theme
                else self._queued_close_on_success or close_on_success
            )
            self._latest_requested_theme = theme
            self.set_status(f"Queueing {display_name(theme)}...", busy=True)
            self.refresh_rows()
            return

        self._latest_requested_theme = theme
        if immediate:
            self.apply_theme_async(theme, wallpaper, close_on_success=close_on_success)
            return

        self._preview_source_id = GLib.timeout_add(
            PREVIEW_DELAY_MS,
            self._run_scheduled_preview,
            theme,
            wallpaper,
        )

    def _run_scheduled_preview(self, theme, wallpaper):
        self._preview_source_id = 0
        if self.pending_theme is None and theme == self._latest_requested_theme:
            self.apply_theme_async(theme, wallpaper, close_on_success=False)
        return False

    def apply_theme_async(self, theme, wallpaper, close_on_success):
        if theme == self.current_theme and wallpaper == self.current_wallpaper and self.pending_theme is None:
            if close_on_success:
                self.close()
            return

        self._request_serial += 1
        request_id = self._request_serial
        self._active_request_id = request_id
        self.pending_theme = theme
        self._queued_theme = None
        self._queued_wallpaper = None
        self._queued_close_on_success = False
        self.set_status(f"Applying {display_name(theme)}...", busy=True)
        self.refresh_rows()

        worker = threading.Thread(
            target=self._apply_theme_worker,
            args=(request_id, theme, wallpaper, close_on_success),
            daemon=True,
        )
        worker.start()

    def _run_theme_apply(self, theme, wallpaper=None):
        args = ["apply", theme]
        if wallpaper == RANDOM_WALLPAPER_TOKEN:
            args.append("--random-wallpaper")
        elif wallpaper:
            args.extend(["--wallpaper", wallpaper])
        run_cli(*args, extra_env=APPLY_ENV)

    def _apply_theme_worker(self, request_id, theme, wallpaper, close_on_success):
        error = None
        try:
            with self._apply_lock:
                self._run_theme_apply(theme, wallpaper)
        except RuntimeError as exc:
            error = str(exc)

        GLib.idle_add(
            self._finish_apply_theme,
            request_id,
            theme,
            wallpaper,
            close_on_success,
            error,
        )

    def _finish_apply_theme(self, request_id, theme, wallpaper, close_on_success, error):
        if self._destroyed:
            return False
        if request_id != self._active_request_id:
            return False

        pending_was = self.pending_theme
        self._active_request_id = 0
        self.pending_theme = None

        if error is None:
            self.reload_metadata()
            self.current_theme = theme
            self.current_wallpaper = self.metadata_for(theme).get("selected_wallpaper", "") or (wallpaper or "")
            self._local_wallpaper_choices.pop(theme, None)
            self._mark_recent_theme(theme)
            self.set_status(f"Previewing {display_name(theme)}", busy=False)
            self.refresh_rows()
            if close_on_success:
                self.close()
                return False
        else:
            self.set_status(error, busy=False)
            if pending_was == theme:
                self.refresh_rows()

        if self._queued_theme and (
            self._queued_theme != self.current_theme or self._queued_wallpaper != self.current_wallpaper
        ):
            queued_theme = self._queued_theme
            queued_wallpaper = self._queued_wallpaper
            queued_close_on_success = self._queued_close_on_success
            self._queued_theme = None
            self._queued_wallpaper = None
            self._queued_close_on_success = False
            self.apply_theme_async(
                queued_theme,
                queued_wallpaper,
                close_on_success=queued_close_on_success,
            )
            return False

        if self._close_when_idle and error is None:
            self.close()
            return False

        return False

    def set_default_theme(self, theme):
        try:
            run_cli("default", theme)
        except RuntimeError:
            return

        self.default_theme = theme
        self.set_status(f"Default set to {display_name(theme)}", busy=False)
        self.refresh_rows()

    def toggle_favorite_theme(self, theme):
        try:
            result = run_cli("favorite", "toggle", theme)
        except RuntimeError:
            return
        action = result.stdout.strip() or "updated"
        item = self.theme_metadata.get(theme)
        if item is not None:
            item["favorite"] = action == "added"
        self.set_status(f"Favorite {action} for {display_name(theme)}", busy=False)
        self.apply_filters(refresh_status=False)

    def current_preview_theme(self):
        return self.selected_theme() or self.current_theme or self.default_theme

    def on_close_request(self, _window):
        if self._preview_source_id:
            GLib.source_remove(self._preview_source_id)
            self._preview_source_id = 0

        if self._reverting or self._confirmed:
            return False

        if self.pending_theme is not None:
            self._close_when_idle = True
            self._queued_theme = self.initial_theme or self.current_theme or self.pending_theme
            self._queued_wallpaper = self.initial_wallpaper or None
            self._queued_close_on_success = False
            self.set_status("Finishing preview before closing...", busy=True)
            self.refresh_rows()
            return True

        if self.initial_theme and (
            self.current_theme != self.initial_theme or self.current_wallpaper != self.initial_wallpaper
        ):
            self._reverting = True
            try:
                self._run_theme_apply(self.initial_theme, self.initial_wallpaper or None)
                self.current_theme = self.initial_theme
                self.current_wallpaper = self.initial_wallpaper
            except RuntimeError:
                pass
            finally:
                self._reverting = False

        return False

    def on_destroy(self, _widget):
        self._save_gui_state()
        self._destroyed = True

    def set_status(self, message, busy=False):
        if self._destroyed:
            return
        self.status_label.set_text(message)
        if busy == getattr(self, "_status_busy", None):
            return
        self._status_busy = busy
        self.spinner.set_spinning(busy)
        sensitive = not busy
        for widget in (
            self.apply_button,
            self.preview_favorite_button,
            self.preview_default_button,
            self.wallpaper_dropdown,
            self.wallpaper_browse_button,
            self.wallpaper_randomize_button,
            self.details_button,
            self.desktop_preview_switch,
        ):
            widget.set_sensitive(sensitive)

    def on_wallpaper_browse_clicked(self, button):
        theme = self.current_preview_theme()
        if not theme:
            return
        metadata = self.metadata_for(theme)
        wallpapers = [item for item in metadata.get("wallpapers", []) if item.get("name")]
        if not wallpapers:
            return

        if self.wallpaper_popover is not None:
            self.wallpaper_popover.popdown()

        self.wallpaper_popover = Gtk.Popover()
        self.wallpaper_popover.set_parent(button)
        self.wallpaper_popover.set_has_arrow(True)
        self.wallpaper_popover.set_autohide(True)

        scroller = Gtk.ScrolledWindow()
        scroller.set_min_content_width(480)
        scroller.set_min_content_height(260)
        grid = Gtk.Grid()
        grid.set_column_spacing(8)
        grid.set_row_spacing(8)
        grid.set_margin_top(10)
        grid.set_margin_bottom(10)
        grid.set_margin_start(10)
        grid.set_margin_end(10)

        for index, wallpaper in enumerate(wallpapers):
            choice = wallpaper.get("name", "")
            label = wallpaper.get("label") or wallpaper_label(choice)
            tile = Gtk.Button()
            tile.add_css_class("wallpaper-thumb")
            tile.connect("clicked", self.on_wallpaper_thumb_clicked, theme, choice)
            tile_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
            try:
                pixbuf = GdkPixbuf.Pixbuf.new_from_file_at_scale(
                    wallpaper.get("path", ""),
                    WALLPAPER_THUMB_WIDTH,
                    WALLPAPER_THUMB_HEIGHT,
                    True,
                )
                tile_box.append(Gtk.Image.new_from_paintable(Gdk.Texture.new_for_pixbuf(pixbuf)))
            except (GLib.Error, OSError):
                tile_box.append(Gtk.Label(label="No preview"))
            tile_label = Gtk.Label(label=label)
            tile_label.set_wrap(True)
            tile_label.set_max_width_chars(18)
            tile_box.append(tile_label)
            tile.set_child(tile_box)
            grid.attach(tile, index % 3, index // 3, 1, 1)

        scroller.set_child(grid)
        self.wallpaper_popover.set_child(scroller)
        self.wallpaper_popover.popup()

    def on_wallpaper_thumb_clicked(self, _button, theme, wallpaper):
        if self.wallpaper_popover is not None:
            self.wallpaper_popover.popdown()
        self._set_local_wallpaper_choice(theme, wallpaper)
        self._select_wallpaper_choice(wallpaper)
        self.refresh_preview(update_wallpaper_selector=False)
        if self.desktop_preview_enabled:
            self.schedule_preview(theme, wallpaper=wallpaper, immediate=True)
        else:
            self.set_status(f"Selected wallpaper for {display_name(theme)}", busy=False)

    def on_details_clicked(self, button):
        theme = self.current_preview_theme()
        if not theme:
            return
        metadata = self.metadata_for(theme)
        if self.details_popover is not None:
            self.details_popover.popdown()

        self.details_popover = Gtk.Popover()
        self.details_popover.set_parent(button)
        self.details_popover.set_has_arrow(True)
        self.details_popover.set_autohide(True)

        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        box.set_margin_top(12)
        box.set_margin_bottom(12)
        box.set_margin_start(12)
        box.set_margin_end(12)
        box.set_size_request(340, -1)

        title = Gtk.Label(xalign=0)
        title.set_text(metadata.get("name") or display_name(theme))
        title.add_css_class("preview-title")
        box.append(title)

        details = [
            f"Slug: {theme}",
            f"Variant: {(metadata.get('variant') or 'dark').title()}",
            f"Source: {metadata.get('source', 'theme')}",
            f"Wallpapers: {len(metadata.get('wallpapers', []))}",
        ]
        path = metadata.get("path", "")
        if path:
            details.append(f"Path: {path}")
        targets = metadata.get("targets", [])
        if targets:
            details.append("Includes: " + ", ".join(targets))
        if metadata.get("favorite"):
            details.append("Favorite: yes")
        if theme == self.current_theme:
            details.append("Current: yes")
        if theme == self.default_theme:
            details.append("Default: yes")

        for detail in details:
            label = Gtk.Label(xalign=0)
            label.add_css_class("dim-label")
            label.set_wrap(True)
            label.set_text(detail)
            box.append(label)

        self.details_popover.set_child(box)
        self.details_popover.popup()

    def show_row_menu(self, row, x, y):
        if self.menu_popover is not None:
            self.menu_popover.popdown()

        self.menu_popover = Gtk.Popover()
        self.menu_popover.add_css_class("menu-popover")
        self.menu_popover.set_has_arrow(True)
        self.menu_popover.set_autohide(True)
        self.menu_popover.set_parent(row)

        menu_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        default_button = Gtk.Button(label="Set as default")
        default_button.add_css_class("menu-button")
        default_button.connect("clicked", self.on_set_default_clicked, row.theme)
        menu_box.append(default_button)

        favorite_label = "Remove favorite" if self.metadata_for(row.theme).get("favorite") else "Add favorite"
        favorite_button = Gtk.Button(label=favorite_label)
        favorite_button.add_css_class("menu-button")
        favorite_button.connect("clicked", self.on_toggle_favorite_clicked, row.theme)
        menu_box.append(favorite_button)
        self.menu_popover.set_child(menu_box)

        rect = Gdk.Rectangle()
        rect.x = int(x)
        rect.y = int(y)
        rect.width = 1
        rect.height = 1
        self.menu_popover.set_pointing_to(rect)
        self.menu_popover.popup()

    def on_set_default_clicked(self, _button, theme):
        if self.menu_popover is not None:
            self.menu_popover.popdown()
        self.set_default_theme(theme)

    def on_toggle_favorite_clicked(self, _button, theme):
        if self.menu_popover is not None:
            self.menu_popover.popdown()
        self.toggle_favorite_theme(theme)

    def on_preview_set_default_clicked(self, _button):
        theme = self.current_preview_theme()
        if theme is None:
            return
        self.set_default_theme(theme)

    def on_preview_toggle_favorite_clicked(self, _button):
        theme = self.current_preview_theme()
        if theme is None:
            return
        self.toggle_favorite_theme(theme)


class ThemeLauncherApp(Gtk.Application):
    def __init__(self):
        super().__init__(application_id="local.theme.launcher")

    def do_activate(self):
        window = self.props.active_window
        if window is None:
            window = ThemeLauncherWindow(self)
        window.present()


def main():
    app = ThemeLauncherApp()
    return app.run(sys.argv)


if __name__ == "__main__":
    raise SystemExit(main())
