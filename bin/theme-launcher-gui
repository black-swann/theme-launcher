def run_cli(*args, check=True, extra_env=None):
    env = os.environ.copy()
    if extra_env:
        env.update(extra_env)
    result = subprocess.run(
        [str(CLI), *args],
        capture_output=True,
        text=True,
        check=False,
        env=env,
    )
    if check and result.returncode != 0:
        message = result.stderr.strip() or result.stdout.strip() or "Command failed"
        raise RuntimeError(message)
    return result


def display_name(theme):
    return " ".join(part.capitalize() for part in theme.split("-"))


def wallpaper_label(name):
    stem = Path(name).stem
    cleaned = stem.lstrip("0123456789").lstrip("-_").replace("-", " ").replace("_", " ")
    return (cleaned or stem).title()


def theme_variant_label(metadata):
    variant = (metadata.get("variant") or "dark").strip().lower()
    if variant == "light":
        return "Light Theme"
    return "Dark Theme"


def infer_theme_vibe(theme, metadata):
    slug = (theme or "").strip().lower()
    text_parts = [
        slug.replace("-", " "),
        str(metadata.get("name") or "").lower(),
        str(metadata.get("description") or "").lower(),
        " ".join(str(tag).lower() for tag in metadata.get("tags", [])),
    ]
    haystack = " ".join(part for part in text_parts if part)

    keyword_map = [
        ("light", "Clean airy minimalism"),
        ("snow", "Clean airy minimalism"),
        ("white", "Clean airy minimalism"),
        ("latte", "Soft warm minimalism"),
        ("rose", "Soft warm romance"),
        ("pink", "Soft neon romance"),
        ("sakura", "Soft floral calm"),
        ("gold", "Warm luxe glow"),
        ("amber", "Warm amber glow"),
        ("sunset", "Warm cinematic dusk"),
        ("solar", "Warm retro clarity"),
        ("forest", "Earthy woodland calm"),
        ("jade", "Earthy polished calm"),
        ("garden", "Earthy natural calm"),
        ("green", "Earthy natural calm"),
        ("ever", "Earthy natural calm"),
        ("dracula", "Moody gothic contrast"),
        ("midnight", "Moody midnight contrast"),
        ("night", "Moody midnight contrast"),
        ("dark", "Moody focused contrast"),
        ("black", "Moody inky minimalism"),
        ("void", "Moody inky minimalism"),
        ("mono", "Monochrome crisp minimalism"),
        ("catppuccin", "Soft creamy contrast"),
        ("gruv", "Earthy retro contrast"),
        ("nord", "Cool arctic calm"),
        ("frost", "Cool arctic calm"),
        ("ice", "Cool arctic calm"),
        ("blue", "Cool electric clarity"),
        ("azure", "Cool electric clarity"),
        ("cobalt", "Cool electric clarity"),
        ("tokyo", "Neon city glow"),
        ("cyber", "Neon cyberpunk energy"),
        ("punk", "Neon cyberpunk energy"),
        ("synth", "Neon retro futurism"),
        ("retro", "Neon retro futurism"),
        ("wave", "Neon retro futurism"),
        ("space", "Cosmic retro adventure"),
        ("mars", "Cosmic red drama"),
        ("aether", "Ethereal luminous haze"),
        ("ethereal", "Ethereal luminous haze"),
        ("ghost", "Ethereal pastel haze"),
        ("pastel", "Ethereal pastel haze"),
        ("vapor", "Dreamy vapor haze"),
        ("aura", "Dreamy luminous haze"),
    ]

    for keyword, vibe in keyword_map:
        if keyword in haystack:
            return vibe

    if (metadata.get("variant") or "dark").strip().lower() == "light":
        return "Clean balanced clarity"
    return "Moody focused contrast"


def theme_row_summary(theme, metadata):
    return f"{theme_variant_label(metadata)} - {infer_theme_vibe(theme, metadata)}"


class ThemeRow(Gtk.ListBoxRow):
    def __init__(self, theme, window):
        super().__init__()
        self.theme = theme
        self.window = window
        self.add_css_class("theme-row")

        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
        box.set_margin_top(8)
        box.set_margin_bottom(8)
        box.set_margin_start(14)
        box.set_margin_end(14)
        self.box = box

        self.title_label = Gtk.Label(xalign=0)
        self.title_label.set_text(display_name(theme))
        self.title_label.add_css_class("theme-title")

        header = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        header.append(self.title_label)

        self.badge_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=6)
        self.badge_box.set_halign(Gtk.Align.END)
        self.badge_box.set_hexpand(True)
        header.append(self.badge_box)

        self.meta_label = Gtk.Label(xalign=0)
        self.meta_label.add_css_class("dim-label")
        self.meta_label.add_css_class("theme-meta")

        box.append(header)
        box.append(self.meta_label)
        self.set_child(box)

        gesture = Gtk.GestureClick.new()
        gesture.set_button(3)
        gesture.connect("pressed", self.on_secondary_click)
        self.add_controller(gesture)

    def refresh(self):
        self.remove_css_class("current")
        self.remove_css_class("pending")
        self._clear_badges()
        metadata = self.window.metadata_for(self.theme)

        if self.theme == self.window.current_theme:
            self.add_css_class("current")
            self._add_badge("Current", "current-badge")
        if self.theme == self.window.default_theme:
            self._add_badge("Default", "default-badge")
        if self.theme == self.window.pending_theme:
            self.add_css_class("pending")
            self._add_badge("Applying", "pending-badge")

        if metadata.get("favorite"):
            self._add_badge("Favorite", "default-badge")

        self.meta_label.set_text(theme_row_summary(self.theme, metadata))

        self.meta_label.set_visible(bool(self.meta_label.get_text()))

    def on_secondary_click(self, _gesture, _presses, x, y):
        self.window.list_box.select_row(self)
        self.window.show_row_menu(self, x, y)

    def _add_badge(self, text, css_class):
        label = Gtk.Label(label=text)
        label.add_css_class("theme-badge")
        label.add_css_class(css_class)
        self.badge_box.append(label)

    def _clear_badges(self):
        child = self.badge_box.get_first_child()
        while child is not None:
            next_child = child.get_next_sibling()
            self.badge_box.remove(child)
            child = next_child


